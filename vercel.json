{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/hub/(.*)", "dest": "/hub/$1.html" },
    { "src": "/(dashboard|quiz|blog|admin)", "dest": "/$1.html" },
    { "src": "/(css|js)/(.*)", "dest": "/$1/$2" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
