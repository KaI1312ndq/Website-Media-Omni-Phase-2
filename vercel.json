{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/hub/:page", "destination": "/hub/:page.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/quiz", "destination": "/quiz.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/:id", "destination": "/blog.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "redirects": [
    { "source": "/dashboard.html", "destination": "/dashboard", "permanent": false },
    { "source": "/quiz.html", "destination": "/quiz", "permanent": false },
    { "source": "/blog.html", "destination": "/blog", "permanent": false },
    { "source": "/admin.html", "destination": "/admin", "permanent": false }
  ]
}
