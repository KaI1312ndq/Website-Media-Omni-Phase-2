NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Token must have READ + WRITE permission (Sanity manage > API > Tokens > "Editor" or higher).
# Required for: scripts/seed-sanity.ts and on-demand revalidation.
SANITY_API_TOKEN=your_write_token

# Notifications API hardening (optional). When set, POST /api/notifications
# requires header `x-internal-key: <value>` for cross-service callers.
INTERNAL_API_KEY=

# Sentry (optional — leave empty to disable; build still works)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
