# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_write_token

# Sanity revalidation webhook secret (for /api/revalidate)
SANITY_REVALIDATE_SECRET=your_random_secret

# Supabase (internal hub)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI (Weekly Report tool)
OPENAI_API_KEY=sk-...

# Google Analytics 4 — optional. If unset, GA scripts are skipped.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
